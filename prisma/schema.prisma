generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id          String   @id @default(cuid())
  name        String?
  email       String   @unique
  image       String?
  plan        String   @default("basic")
  createdAt   DateTime @default(now())
  lastLogin   DateTime @updatedAt
}



