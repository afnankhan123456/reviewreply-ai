generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                  String              @id @default(cuid())
  name                String?
  email               String              @unique
  image               String?

  plan                String              @default("basic")

  subscriptionStatus  String              @default("active")
  subscriptionStart   DateTime            @default(now())
  subscriptionEnd     DateTime?

  reviewsUsed         Int                 @default(0)
  reviewsLimit        Int                 @default(100)

  locationsUsed       Int                 @default(0)
  locationsLimit      Int                 @default(1)

  googleConnected     Boolean             @default(false)

  lastReviewSync      DateTime?
  syncEnabled         Boolean             @default(true)

  monthlyResetDate    DateTime?           // 30‑day sync window start

  // Gmail alert fields
  gmailConnected      Boolean             @default(false)   // whether Gmail is connected for alerts
  alertEmailsSent     Int                 @default(0)       // count of alert emails sent this month
  alertEmailsLimit    Int                 @default(100)     // 100 emails/month limit
  alertMonthlyReset   DateTime?           // 30‑day reset date for alert counter

  createdAt           DateTime            @default(now())
  lastLogin           DateTime            @default(now())

  // 👇 NEW FIELD ADDED (Kuch remove nahi kiya)
  referralCode        String              @unique

  businessLocations   BusinessLocation[]
  reviews             Review[]
  templates           Template[]          // relation to templates
  reports             Report[]            // relation to reports
  exports             Export[]            // relation to exports
  bugReports          BugReport[]         // relation to bug reports
}

model BusinessLocation {
  id               String   @id @default(cuid())

  userId           String
  user             User     @relation(fields: [userId], references: [id])

  googleLocationId String   @unique
  businessName     String
  address          String?

  createdAt        DateTime @default(now())

  reviews          Review[]
}

model Review {
  id               String   @id @default(cuid())

  userId           String
  user             User     @relation(fields: [userId], references: [id])

  businessLocationId String
  businessLocation   BusinessLocation @relation(fields: [businessLocationId], references: [id])

  googleReviewId   String   @unique

  reviewerName     String
  reviewerPhoto    String?

  rating           Int

  comment          String?

  reviewReply      String?

  replied          Boolean  @default(false)

  reviewDate       DateTime
  syncedAt         DateTime @default(now())

  createdAt        DateTime @default(now())
}

model Template {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  title     String
  content   String
  category  String   @default("general")   // e.g., "positive", "negative", "general"
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Report {
  id             String   @id @default(cuid())
  userId         String
  user           User     @relation(fields: [userId], references: [id])
  title          String
  type           String   @default("monthly")   // "monthly", "custom"
  averageRating  Float?
  totalReviews   Int?
  fileUrl        String?                       // URL to download the report (if generated)
  createdAt      DateTime @default(now())
}

model Export {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  type      String   // "csv" or "pdf"
  fileName  String
  createdAt DateTime @default(now())
}

model BugReport {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  feature     String
  issueType   String
  description String
  status      String   @default("Open")   // new field: "Open" or "Resolved"
  createdAt   DateTime @default(now())
}
