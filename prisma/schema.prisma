generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                  String              @id @default(cuid())
  name                String?
  email               String              @unique
  image               String?
  plan                String              @default("basic")
  subscriptionStatus  String              @default("active")
  subscriptionStart   DateTime            @default(now())
  subscriptionEnd     DateTime?
  reviewsUsed         Int                 @default(0)
  reviewsLimit        Int                 @default(100)
  locationsUsed       Int                 @default(0)
  locationsLimit      Int                 @default(1)
  teamMembersLimit    Int                 @default(2)
  googleConnected     Boolean             @default(false)
  lastReviewSync      DateTime?
  syncEnabled         Boolean             @default(true)
  slug                String?             @unique
  monthlyResetDate    DateTime?
  gmailConnected      Boolean             @default(false)
  googleBusinessConnected  Boolean        @default(false)
  businessEmail       String?
  googleAccessToken   String?             @db.Text
  googleRefreshToken  String?             @db.Text
  googlePlaceId       String?
  alertEmailsSent     Int                 @default(0)
  alertEmailsLimit    Int                 @default(100)
  criticalEmailsSent  Int                 @default(0)
  criticalEmailsLimit Int                 @default(0)
  alertMonthlyReset   DateTime?
  createdAt           DateTime            @default(now())
  lastLogin           DateTime            @default(now())
  referralCode        String              @unique
  businessLocations   BusinessLocation[]
  reviews             Review[]
  templates           Template[]
  reports             Report[]
  exports             Export[]
  bugReports          BugReport[]
  referralClicks      ReferralClick[]
  referralSignups     ReferralSignup[]
  referralStats       ReferralStats[]
  reviewRequests      ReviewRequest[]
  tagCycles           TagCycle[]
  lastWeeklyReportSent DateTime?
  lastExpiryNotified   DateTime?
  teamMembersOwned    TeamMember[]        @relation("TeamOwner")
  teamMembershipOf    TeamMember[]        @relation("TeamMembership")
  articleFeedback     ArticleFeedback[]
}

model BusinessLocation {
  id               String   @id @default(cuid())
  userId           String
  user             User     @relation(fields: [userId], references: [id])
  googleLocationId String   @unique
  businessName     String
  address          String?
  createdAt        DateTime @default(now())
  reviews          Review[]
}

model Review {
  id               String   @id @default(cuid())
  userId           String
  user             User     @relation(fields: [userId], references: [id])
  businessLocationId String?
  businessLocation   BusinessLocation? @relation(fields: [businessLocationId], references: [id])
  googleReviewId   String?   @unique
  reviewerName     String
  reviewerPhoto    String?
  source           String?
  rating           Int
  comment          String?
  text             String?
  reviewReply      String?
  replied          Boolean  @default(false)
  aiReplied        Boolean  @default(false)
  reviewDate       DateTime
  syncedAt         DateTime @default(now())
  createdAt        DateTime @default(now())
  tags             String[] @default([])
}

model Template {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  title     String
  content   String
  category  String   @default("general")
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Report {
  id             String    @id @default(cuid())
  userId         String
  user           User      @relation(fields: [userId], references: [id])
  title          String
  type           String    @default("monthly")
  averageRating  Float?
  totalReviews   Int?
  fileUrl        String?
  periodStart    DateTime?
  periodEnd      DateTime?
  createdAt      DateTime  @default(now())
}

model Export {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  type      String
  fileName  String
  createdAt DateTime @default(now())
}

model BugReport {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  feature     String
  issueType   String
  description String
  status      String   @default("Open")
  createdAt   DateTime @default(now())
}

model ReferralClick {
  id             String   @id @default(cuid())
  referrerEmail  String
  clickerEmail   String?
  clickedAt      DateTime @default(now())
  user           User?    @relation(fields: [referrerEmail], references: [email])
}

model ReferralSignup {
  id             String   @id @default(cuid())
  referrerEmail  String
  signupEmail    String
  signupDate     DateTime @default(now())
  user           User?    @relation(fields: [referrerEmail], references: [email])
}

model ReferralStats {
  id                Int      @id @default(autoincrement())
  userId            String   @map("user_id")
  referralCode      String   @map("referral_code")
  referralClicks    Int      @default(0) @map("referral_clicks")
  googleSignups     Int      @default(0) @map("google_signups")
  paidSubscriptions Int      @default(0) @map("paid_subscriptions")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")
  user              User     @relation(fields: [userId], references: [id])
  @@map("referral_stats")
}

model PartnerWhitelist {
  id        String   @id @default(cuid())
  email     String   @unique
  createdAt DateTime @default(now())
  @@map("partner_whitelist")
}

model Withdrawal {
  id          String   @id @default(cuid())
  email       String
  upiId       String
  name        String
  phoneNumber String
  status      String   @default("Pending")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  @@map("withdrawals")
}

model ReviewRequest {
  id             String    @id @default(cuid())
  userId         String
  user           User      @relation(fields: [userId], references: [id])
  customerName   String
  customerEmail  String
  template       String    @default("standard")
  sendAfterHours Int       @default(24)
  scheduledAt    DateTime
  status         String    @default("pending")
  sentAt         DateTime?
  createdAt      DateTime  @default(now())
}

model TagCycle {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id])
  cycleStart DateTime
  cycleEnd   DateTime
  createdAt  DateTime @default(now())
}

model TeamMember {
  id           String    @id @default(cuid())
  ownerId      String
  owner        User      @relation("TeamOwner", fields: [ownerId], references: [id])
  email        String
  accessLevel  String    @default("VIEW_ONLY")
  status       String    @default("PENDING")
  memberUserId String?
  member       User?     @relation("TeamMembership", fields: [memberUserId], references: [id])
  inviteToken  String?   @unique
  invitedAt    DateTime  @default(now())
  acceptedAt   DateTime?

  @@unique([ownerId, email])
}

model KnowledgeArticle {
  id        String   @id @default(cuid())
  title     String
  content   String
  category  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  feedback  ArticleFeedback[]
}

model ArticleFeedback {
  id        String           @id @default(cuid())
  articleId String
  article   KnowledgeArticle @relation(fields: [articleId], references: [id])
  userId    String
  user      User             @relation(fields: [userId], references: [id])
  helpful   Boolean
  createdAt DateTime         @default(now())

  @@unique([articleId, userId])
}
